{
  "name": "mockmate",
  "version": "1.4.2",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Real-Time AI Interview Companion — floats over Zoom/Teams/Meet, invisible to screen capture",
  "author": "MockMate",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently \"PORT=3002 node server.js\" \"vite\"",
    "build": "vite build",
    "electron:dev": "concurrently -k \"PORT=3002 node server.js\" \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:dev:nosandbox": "concurrently -k \"PORT=3002 node server.js\" \"vite\" \"wait-on http://localhost:5174 && electron . --no-sandbox\"",
    "electron:win": "vite build && electron-builder --win",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "server": "node server.js",
    "vite": "vite",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.mockmate.app",
    "productName": "MockMate",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "api/**/*",
      "shared/**/*",
      "backend/**/*",
      "!backend/node_modules/**/*",
      "server.js",
      "server-entry.cjs",
      "setup.html",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/.cache/**/*"
    ],
    "extraFiles": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "MockMate-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "MockMate"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "vsv2014",
        "repo": "MockMate"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity",
      "artifactName": "MockMate-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "MockMate listens to interview audio to generate real-time answer suggestions.",
        "NSCameraUsageDescription": "MockMate may capture screen content to analyze on-screen questions."
      }
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "artifactName": "MockMate-${version}.${ext}"
    }
  },
  "dependencies": {
    "@sentry/electron": "^7.14.0",
    "@sentry/node": "^10.60.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.0",
    "stripe": "^17.5.0",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "openai": "^6.25.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^32.3.3",
    "electron-builder": "^24.0.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.0"
  }
}
